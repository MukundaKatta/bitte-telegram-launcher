{
  "name": "bitte-telegram-launcher",
  "version": "0.1.0",
  "description": "Reusable launcher that turns any Bitte agent into a Telegram or Discord bot",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bitte-launch": "dist/bin/bitte-launch.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "tsx bin/bitte-launch.ts"
  },
  "keywords": [
    "bitte",
    "telegram",
    "discord",
    "agent",
    "launcher",
    "near"
  ],
  "author": "Mukunda Katta",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "discord.js": "^14.16.3",
    "telegraf": "^4.16.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.0"
  }
}
